{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Desktop Bot Hub",
  "version": "0.1.0",
  "identifier": "com.openclaw.desktop-bot-hub",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "character",
        "title": "OpenClaw Character",
        "url": "index.html?mode=character&label=character&index=0",
        "width": 362,
        "height": 276,
        "decorations": false,
        "transparent": true,
        "acceptFirstMouse": true,
        "skipTaskbar": true,
        "resizable": false,
        "shadow": false,
        "fullscreen": false,
        "alwaysOnTop": true
      },
      {
        "label": "bubble",
        "title": "OpenClaw Bubble",
        "url": "index.html?mode=bubble",
        "width": 360,
        "height": 520,
        "decorations": false,
        "transparent": true,
        "acceptFirstMouse": true,
        "skipTaskbar": true,
        "resizable": false,
        "shadow": false,
        "fullscreen": false,
        "alwaysOnTop": true,
        "visible": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
